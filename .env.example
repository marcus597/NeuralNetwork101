# Wonder API — Environment Variables

# Public site URL (sitemap, OG, share links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# JWT signing secret for session cookies (required in production)
WONDER_JWT_SECRET=change-me-in-production-use-openssl-rand

# Firebase REST API key (optional — enables POST /api/auth/session)
# Without this, only anonymous mode works server-side
FIREBASE_API_KEY=

# Wonder is free at launch — no paid env vars required

# v2: Redis for persistent storage across serverless instances
# WONDER_REDIS_URL=

# v2: PostHog analytics forwarding
# NEXT_PUBLIC_POSTHOG_KEY=
# POSTHOG_HOST=
